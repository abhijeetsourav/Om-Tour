GROQ_API_KEY=
GOOGLE_MAPS_API_KEY=
LANGSMITH_TRACING_V2=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT="Om-tour"
LANGSMITH_CALLBACKS_BACKGROUND=true
LANGSMITH_ENDPOINT=https://smith.langchain.com


# Hugging Face API
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=Qwen/Qwen2.5-7B-Instruct
HUGGINGFACE_CRITIC_MODEL=meta-llama/Llama-3.3-70B-Instruct
HUGGINGFACE_VALIDATOR_MODEL=microsoft/deberta-base-mnli
HUGGINGFACE_FORMATTER_MODEL=Qwen/Qwen2.5-7B-Instruct

# Disable LLM critic by default - rule-based validation is fast and sufficient
# Set to "true" to enable semantic critique (slower, but more thorough)
USE_LLM_CRITIC=false